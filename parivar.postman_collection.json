							"pm.environment.set('token', jsonData.data?.token || '');",
							"pm.sendRequest({",
							"  url: pm.environment.get('parivar') + 'select_account_login',",
							"  method: 'POST',",
							"  header: { 'Authorization': 'Bearer ' + pm.environment.get('token') },",
							"  body: { mode: 'formdata', formdata: [ { key: 'member_id', value: '24', type: 'text' } ] }",
							"}, function (err, res) {",
							"  if (res && res.json) {",
